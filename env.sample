# Odoo base URL (base host, /jsonrpc, or /json/2)
ODOO_URL=https://your-company.odoo.com
ODOO_DB=your_company_db

# Optional default API key (used only when user_email is not provided)
ODOO_API_KEY=
ODOO_DEFAULT_USER_EMAIL=appmanagent@technicalservices.us

# JSON object: email -> API key
ODOO_USER_API_KEYS={"alice@example.com":"api_key_1","bob@example.com":"api_key_2"}

# Require user email on every request
ODOO_REQUIRE_USER_EMAIL=true

# Optional support for API key via request header
ODOO_ALLOW_API_KEY_HEADER=false
ODOO_USER_EMAIL_HEADER=x-odoo-user-email
ODOO_API_KEY_HEADER=x-odoo-api-key
